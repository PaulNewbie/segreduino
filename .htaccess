RewriteEngine On

# Never rewrite actual files (css, js, images, fonts)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Skip rewriting for the assets directory entirely
RewriteRule ^(assets|db_backup|src/vendor)/ - [L,NC]

# Route everything else through index.php
RewriteRule ^ index.php [QSA,L]