RewriteEngine On

# 1. Skip rewriting for these directories entirely (serve them directly)
RewriteRule ^(assets|db_backup|src/vendor)/ - [L,NC]

# 2. For everything else, if it is NOT a real file...
RewriteCond %{REQUEST_FILENAME} !-f
# ...and NOT a real directory...
RewriteCond %{REQUEST_FILENAME} !-d
# 3. THEN route it through index.php
RewriteRule ^ index.php [QSA,L]